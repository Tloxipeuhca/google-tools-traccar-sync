# Copy this file to .env (in the Traccar/ directory) and fill in your values
# before running docker compose.

# URL of your Traccar server (OsmAnd HTTP endpoint)
TRACCAR_SERVER_URL=http://traccar:8082

# Port exposed by the Flask service on the host
PORT=5002

# Bearer token required on every API request (Authorization: Bearer <token>)
# Leave empty or unset to disable authentication (development only)
API_TOKEN=change-me-to-a-strong-random-secret

# ---------------------------------------------------------------------------
# Auto-registration of sync services
# ---------------------------------------------------------------------------

# Set to false to disable automatic service registration entirely
AUTO_REGISTER_SERVICES=true

# Default sync interval (seconds) applied when auto-registering a new service
AUTO_REGISTER_TIMER=600

# Default jitter (seconds) applied when auto-registering a new service
AUTO_REGISTER_DELTA=5

# ---------------------------------------------------------------------------
# Smart tracking (adaptive interval)
# Set SMART_TRACKING_ENABLED=false to disable entirely
# ---------------------------------------------------------------------------

# Enable intelligent adaptive interval (default: true)
SMART_TRACKING_ENABLED=true

# Distance threshold in metres that triggers intensive mode (default: 200)
SMART_TRACKING_DISTANCE=200

# Duration in seconds of the intensive tracking window (default: 300 = 5 min)
SMART_TRACKING_DURATION=300

# Polling interval in seconds during intensive mode (default: 20)
SMART_TRACKING_TIMER=20

# Jitter (± seconds) applied to the intensive-mode interval (default: 5)
SMART_TRACKING_DELTA=5

# Note: the re-trigger window is automatically equal to the service's normal timer
# (AUTO_REGISTER_TIMER or the value set via PUT /devices/<id>/services).
# No separate parameter is needed.

